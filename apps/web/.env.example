# RutaRentable — copy to `.env` and fill in real values for Supabase.
# With placeholders below, the app runs in MOCK mode (offline demo — no Supabase needed).

# Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# Admin panel access (/admin) — comma-separated emails (must also run:
#   UPDATE public.users SET role = 'admin' WHERE email = '...';
# on Supabase after first signup)
VITE_ADMIN_EMAILS=admin@example.com

# Google Sign-In (optional) — same Web Client ID as Supabase → Auth → Google
# VITE_GOOGLE_WEB_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
